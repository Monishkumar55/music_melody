{
  "name": "songstr-mobile-app",
  "version": "1.0.0",
  "description": "Songstr React Native Mobile Application",
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:apk": "eas build -p android --profile preview",
    "build:apk:local": "expo prebuild --platform android && cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5"
  },
  "private": true
}
